# GitHub API Authentication (optional but recommended)
# Get token from: https://github.com/settings/tokens
# Required scopes: public_repo (read-only)
# Increases rate limit from 60 to 5000 requests/hour
GITHUB_TOKEN=

# Next.js Configuration
# Used for generating shareable result URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analysis Configuration
# Maximum number of files to analyze (prevents hanging on massive repos)
MAX_FILES_TO_ANALYZE=50

# Analysis timeout in milliseconds (ensures completion within user expectation)
ANALYSIS_TIMEOUT_MS=30000